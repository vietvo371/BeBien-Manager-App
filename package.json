{
  "name": "BeBienManager",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --mode=devDebug --appId=vn.com.bebien.manager.dev",
    "android:dev": "sh scripts/set-env.sh development && react-native run-android --mode=devDebug --appId=vn.com.bebien.manager.dev ",
    "android:staging": "sh scripts/set-env.sh staging && react-native run-android --mode=stagingDebug --appId=vn.com.bebien.manager.staging",
    "android:prod": "sh scripts/set-env.sh production && react-native run-android --mode=prodRelease --appId=vn.com.bebien.manager",
    "android:build:dev": "sh scripts/set-env.sh development && cd android && ./gradlew assembleDevRelease",
    "android:build:staging": "sh scripts/set-env.sh staging && cd android && ./gradlew assembleStagingRelease",
    "android:build:prod": "sh scripts/set-env.sh production && cd android && ./gradlew assembleProdRelease",
    "android:bundle:dev": "sh scripts/set-env.sh development && cd android && ./gradlew bundleDevRelease",
    "android:bundle:staging": "sh scripts/set-env.sh staging && cd android && ./gradlew bundleStagingRelease",
    "android:bundle:prod": "sh scripts/set-env.sh production && cd android && ./gradlew bundleProdRelease",
    "android:clean": "cd android && ./gradlew clean",
    "ios": "react-native run-ios",
    "ios:dev": "sh scripts/set-env.sh development && react-native run-ios --simulator='iPhone 16 Plus'",
    "ios:staging": "sh scripts/set-env.sh staging && react-native run-ios --simulator='iPhone 16 Plus'",
    "ios:prod": "sh scripts/set-env.sh production && react-native run-ios --configuration Release",
    "lint": "eslint .",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "test": "jest",
    "env:dev": "sh scripts/set-env.sh development",
    "env:staging": "sh scripts/set-env.sh staging",
    "env:prod": "sh scripts/set-env.sh production",
    "pod:install": "cd ios && bundle exec pod install && cd .."
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "1.16.3",
    "@react-native-community/blur": "4.4.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-firebase/app": "^23.7.0",
    "@react-native-firebase/messaging": "^23.7.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native-picker/picker": "2.11.1",
    "@react-native/new-app-screen": "0.80.1",
    "@react-navigation/bottom-tabs": "7.4.2",
    "@react-navigation/native": "7.1.14",
    "@react-navigation/native-stack": "7.3.21",
    "@tanstack/react-query": "5.90.5",
    "axios": "1.11.0",
    "crypto-js": "4.2.0",
    "i18next": "25.5.2",
    "lottie-react-native": "7.3.4",
    "prop-types": "^15.8.1",
    "react": "19.1.0",
    "react-i18next": "15.7.3",
    "react-native": "0.80.1",
    "react-native-blob-util": "0.24.6",
    "react-native-chart-kit": "6.12.0",
    "react-native-date-picker": "4.3.7",
    "react-native-device-info": "15.0.1",
    "react-native-gesture-handler": "2.28.0",
    "react-native-get-random-values": "1.11.0",
    "react-native-image-picker": "8.2.1",
    "react-native-image-viewing": "0.2.2",
    "react-native-linear-gradient": "2.8.3",
    "react-native-localize": "3.5.2",
    "react-native-paper": "5.14.5",
    "react-native-pdf": "7.0.3",
    "react-native-permissions": "5.4.2",
    "react-native-qrcode-svg": "6.3.15",
    "react-native-ratings": "8.1.0",
    "react-native-reanimated": "4.1.5",
    "react-native-responsive-screen": "1.4.2",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.15.0",
    "react-native-shadow-2": "7.1.2",
    "react-native-shimmer-placeholder": "2.0.9",
    "react-native-svg": "15.15.0",
    "react-native-toast-message": "2.3.3",
    "react-native-vector-icons": "10.3.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.6.0",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "19.0.0",
    "@react-native-community/cli-platform-android": "19.0.0",
    "@react-native-community/cli-platform-ios": "19.0.0",
    "@react-native/babel-preset": "0.80.1",
    "@react-native/eslint-config": "0.80.1",
    "@react-native/metro-config": "0.80.1",
    "@react-native/typescript-config": "0.80.1",
    "@types/crypto-js": "4.2.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "packageManager": "yarn@3.6.4"
}
